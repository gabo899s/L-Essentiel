rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isVerifiedEmail() { return true; /* Disabled verification strictly for MVP guest mode, but we restrict via user ID */ }
    function isAdminEmail() {
      return request.auth.token != null && 'email' in request.auth.token && (
        request.auth.token.email == 'gaboleandro189@gmail.com' || 
        request.auth.token.email.matches('.*ticketpro\\.lat')
      );
    }
    function isAdmin() {
      return isSignedIn() && isAdminEmail();
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProduct(data) {
       return data.keys().hasAll(['name', 'price', 'category']) 
              && data.name is string && data.name.size() > 0 && data.name.size() <= 200
              && data.price is number && data.price >= 0
              && data.category is string && data.category.size() <= 100;
    }

    match /products/{productId} {
      // Allow general read
      allow get: if isValidId(productId);
      allow list: if true; 
      // Admins manage products
      allow create: if isAdmin() && isValidProduct(incoming());
      // Users/Guests ONLY allowed to modify stock when purchasing
      allow update: if isValidId(productId) && (
        isAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock']) && incoming().stock is number && incoming().stock >= 0)
      );
      allow delete: if isAdmin();
    }

    match /promos/{promoId} {
      allow get: if isValidId(promoId);
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /config/global {
      allow get: if true;
      allow list: if true;
    }

    match /wishlists/{userId} {
      allow get: if isValidId(userId) && (isAdmin() || userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && userId == request.auth.uid);
      allow create, update: if isSignedIn() && userId == request.auth.uid;
      allow delete: if isAdmin() || userId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || existing().userId == 'guest');
      // Enforce query restriction
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if incoming().keys().hasAll(['userId', 'items', 'total']) 
                    && incoming().userId is string 
                    && ((isSignedIn() && incoming().userId == request.auth.uid) || incoming().userId == 'guest')
                    && incoming().total >= 0;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow get: if isValidId(chatId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || existing().userId == 'guest');
      // Admin list enforcement
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if incoming().keys().hasAll(['messages', 'userId'])
                    && ((isSignedIn() && incoming().userId == request.auth.uid) || incoming().userId == 'guest');
      allow update: if isValidId(chatId) && (
        isAdmin() || 
        (((isSignedIn() && existing().userId == request.auth.uid) || existing().userId == 'guest') && incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'lastUpdated', 'status', 'rating', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow get: if isValidId(userId) && (isAdmin() || (isSignedIn() && userId == request.auth.uid));
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if isValidId(userId) && (isAdmin() || (isSignedIn() && userId == request.auth.uid));
      allow delete: if isAdmin();
    }
  }
}
